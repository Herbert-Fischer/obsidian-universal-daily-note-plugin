{
  "name": "universal-daily-note-plugin",
  "version": "0.8.0",
  "description": "Universal Daily Note plugin for Obsidian (Denkarium conventions).",
  "main": "main.js",
  "scripts": {
    "dev": "npm run build:css && node esbuild.config.mjs --watch",
    "build:css": "node ../obsidian-platform/packages/lib-ui/scripts/merge-plugin-styles.mjs",
    "build": "npm run build:css && node esbuild.config.mjs && OBSIDIAN_PLUGIN_ID_EXPECT=universal-daily-note export-to-vault",
    "export:plugin": "bash scripts/export-plugin.sh",
    "export:vault": "OBSIDIAN_PLUGIN_ID_EXPECT=universal-daily-note export-to-vault",
    "test": "vitest run --config vitest.config.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "daily-note"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vitest/coverage-v8": "^4.1.6",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.5",
    "esbuild-svelte": "^0.8.2",
    "happy-dom": "^20.9.0",
    "obsidian": "^1.8.7",
    "svelte": "^4.2.20",
    "svelte-preprocess": "^6.0.5",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@denkarium/esbuild-vault-export": "file:../obsidian-platform/packages/esbuild-vault-export",
    "@denkarium/export-to-vault": "file:../obsidian-platform/packages/export-to-vault",
    "@denkarium/obsidian-lib-ui": "file:../obsidian-platform/packages/lib-ui",
    "@denkarium/obsidian-lib-vault": "file:../obsidian-platform/packages/lib-vault",
    "obsidian-daily-notes-interface": "^0.9.4"
  }
}
