# Shared Docker Compose project name — copy this file to `.env` in every plugin repo so all clones use the same stack name (must match top-level `name:` in docker-compose.yml).
COMPOSE_PROJECT_NAME=obsidian-plugin-dev

# Optional: override host vault path (inside container it is always mounted at /vault)
# OBSIDIAN_VAULT_HOST_PATH=/home/hfx/KnowledgeHub/Denkarium_Development

# Parent folder of all plugin git clones on the host (mounted at /workspaces/SoftwareEntwicklung in the container)
# PLUGIN_DEV_HOST_ROOT=/home/hfx/SoftwareEntwicklung
